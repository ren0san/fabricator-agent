# Fabricator agent defaults
AGENT_BACKEND_URL=https://api.thun-der.ru
AGENT_CONFIG_PATH=/etc/fabricator-agent/config.toml
AGENT_TOKEN_FILE=/opt/fabricator-agent/agent.token
AGENT_POLL_SECONDS=10
AGENT_INSTRUCTION_WAIT_SECONDS=25
AGENT_HEARTBEAT_SECONDS=30
AGENT_CONFIG_SYNC_SECONDS=30
AGENT_HTTP_TIMEOUT_SECONDS=10
AGENT_HTTP_PORT=8010
